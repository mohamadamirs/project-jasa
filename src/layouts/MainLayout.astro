---
import { ClientRouter } from 'astro:transitions';
import SEO from '../components/SEO.astro';
import PerformanceBadge from '../components/PerformanceBadge.astro';
import MobileMenu from '../components/react/MobileMenu';
import { SITE_NAME, SITE_DESCRIPTION, WHATSAPP_NUMBER, LUCIDE_ICONS_SCRIPT } from '../consts';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  cityName?: string;
  localContext?: string;
  localLandmark?: string;
  businessTrends?: string;
  lat?: string | number;
  lng?: string | number;
}

const { title, description, cityName, localContext, localLandmark, businessTrends, lat, lng } = Astro.props;
---

<!doctype html>
<html lang="id" class="scroll-smooth overflow-x-hidden">
  <head>
    <SEO {title} {description} {cityName} {localContext} {localLandmark} {businessTrends} {lat} {lng} />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    
    <!-- Lucide Icons Script -->
    <script src={LUCIDE_ICONS_SCRIPT} is:inline></script>
    <ClientRouter />
  </head>
  <body class="bg-white text-slate-900 font-sans selection:bg-blue-100 selection:text-blue-900 overflow-x-hidden w-full relative m-0 p-0">
    <header class="sticky top-0 z-[100] w-full border-b border-slate-100 bg-white shadow-sm">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16 md:h-20 items-center">
          <!-- Logo -->
          <div class="flex-shrink-0 flex items-center">
            <a href="/" class="flex items-center group">
              <img src="/logo.svg" alt={`Logo ${SITE_NAME}`} width={36} height={36} class="h-9 w-9 md:h-10 md:w-10 object-contain group-hover:rotate-12 transition-transform duration-300" />
              <span class="text-base min-[360px]:text-lg md:text-xl font-extrabold tracking-tight text-slate-900 ml-2 md:ml-3 uppercase group-hover:text-blue-600 transition-colors">{SITE_NAME.split(' ')[0]}</span>
            </a>
          </div>
          
          <!-- Desktop Nav -->
          <nav class="hidden md:flex md:space-x-8 items-center">
            <a href="/" class="text-slate-600 hover:text-blue-600 px-3 py-2 text-sm font-bold transition-all active:scale-95">Beranda</a>
            <a href="/portofolio/" class="text-slate-600 hover:text-blue-600 px-3 py-2 text-sm font-bold transition-all active:scale-95">Portofolio</a>
            <a href="/#layanan" class="text-slate-600 hover:text-blue-600 px-3 py-2 text-sm font-bold transition-all active:scale-95">Layanan</a>
            <a href={`https://wa.me/${WHATSAPP_NUMBER}`} class="bg-blue-600 text-white hover:bg-blue-700 px-6 py-3 rounded-xl text-sm font-bold transition-all shadow-lg shadow-blue-200 active:scale-95">Hubungi Kami</a>
          </nav>
          
          <!-- Mobile Menu Toggle -->
          <div class="md:hidden flex items-center">
            <MobileMenu whatsappNumber={WHATSAPP_NUMBER} siteName={SITE_NAME} client:load />
          </div>
        </div>
      </div>
    </header>

    <script>
      function initLucide() {
        if (typeof (window as any).lucide !== 'undefined') {
          (window as any).lucide.createIcons();
        } else {
          setTimeout(initLucide, 100);
        }
      }

      document.addEventListener('astro:page-load', () => {
        initLucide();

        // Intersection Observer
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('active');
            }
          });
        }, { threshold: 0.1 });

        document.querySelectorAll('section').forEach(el => {
          el.classList.add('reveal');
          observer.observe(el);
        });
      });
    </script>

    <main>
      <slot />
    </main>

    <footer class="bg-slate-900 text-slate-300 py-12">
      <div class="container-custom px-[clamp(1rem,5vw,2.5rem)]">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
          <div>
            <h4 class="text-white mb-4 uppercase tracking-widest">{SITE_NAME}</h4>
            <p class="text-sm leading-relaxed mb-6">
              {SITE_DESCRIPTION}
            </p>
            <PerformanceBadge />
          </div>
          <div>
            <h4 class="text-white mb-4 uppercase tracking-widest">Layanan Kami</h4>
            <ul class="space-y-2 text-sm">
              <li>Jasa Website Kustom</li>
              <li>IoT Development</li>
              <li>Sistem Informasi Enterprise</li>
              <li>Optimasi SEO Lokal</li>
            </ul>
          </div>
          <div>
            <h4 class="text-white mb-4 uppercase tracking-widest">Wilayah Layanan</h4>
            <p class="text-sm">Melayani seluruh wilayah Brebes, Bumiayu, Tegal, Slawi, dan sekitarnya secara profesional.</p>
          </div>
        </div>
        <div class="border-t border-slate-800 mt-12 pt-8 text-center text-xs">
          <p>&copy; {new Date().getFullYear()} {SITE_NAME}. Seluruh hak cipta dilindungi.</p>
        </div>
      </div>
    </footer>
  </body>
</html>
