---
import { ClientRouter } from 'astro:transitions';
import SEO from '../components/SEO.astro';
import PerformanceBadge from '../components/PerformanceBadge.astro';
import { SITE_NAME, SITE_DESCRIPTION, WHATSAPP_NUMBER, LUCIDE_ICONS_SCRIPT } from '../consts';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  cityName?: string;
  localContext?: string;
  localLandmark?: string;
  businessTrends?: string;
  lat?: string | number;
  lng?: string | number;
}

const { title, description, cityName, localContext, localLandmark, businessTrends, lat, lng } = Astro.props;
---

<!doctype html>
<html lang="id" class="scroll-smooth overflow-x-hidden">
  <head>
    <SEO {title} {description} {cityName} {localContext} {localLandmark} {businessTrends} {lat} {lng} />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    
    <!-- Lucide Icons Script -->
    <script src={LUCIDE_ICONS_SCRIPT} is:inline></script>
    <ClientRouter />
  </head>
  <body class="bg-white text-slate-900 font-sans selection:bg-blue-100 selection:text-blue-900 overflow-x-hidden w-full relative m-0 p-0">
    <header class="sticky top-0 z-[100] w-full border-b border-slate-100 bg-white shadow-sm">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16 md:h-20 items-center">
          <!-- Logo -->
          <div class="flex-shrink-0 flex items-center">
            <a href="/" class="flex items-center group">
              <img src="/logo.svg" alt={`Logo ${SITE_NAME}`} width={36} height={36} class="h-9 w-9 md:h-10 md:w-10 object-contain group-hover:rotate-12 transition-transform duration-300" />
              <span class="text-lg md:text-xl font-extrabold tracking-tight text-slate-900 ml-2 md:ml-3 uppercase group-hover:text-blue-600 transition-colors">{SITE_NAME.split(' ')[0]}</span>
            </a>
          </div>
          
          <!-- Desktop Nav -->
          <nav class="hidden md:flex md:space-x-8 items-center">
            <a href="/" class="text-slate-600 hover:text-blue-600 px-3 py-2 text-sm font-bold transition-all active:scale-95">Beranda</a>
            <a href="/portofolio/" class="text-slate-600 hover:text-blue-600 px-3 py-2 text-sm font-bold transition-all active:scale-95">Portofolio</a>
            <a href="/#layanan" class="text-slate-600 hover:text-blue-600 px-3 py-2 text-sm font-bold transition-all active:scale-95">Layanan</a>
            <a href={`https://wa.me/${WHATSAPP_NUMBER}`} class="bg-blue-600 text-white hover:bg-blue-700 px-6 py-3 rounded-xl text-sm font-bold transition-all shadow-lg shadow-blue-200 active:scale-95">Hubungi Kami</a>
          </nav>
          
          <!-- Mobile Menu Toggle -->
          <div class="md:hidden flex items-center">
            <button id="mobile-menu-button" type="button" class="text-slate-900 p-2 focus:outline-none" aria-label="Toggle Menu">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-menu"><line x1="3" x2="21" y1="6" y2="6"/><line x1="3" x2="21" y1="12" y2="12"/><line x1="3" x2="21" y1="18" y2="18"/></svg>
            </button>
          </div>
        </div>
      </div>

      <!-- Mobile Menu Backdrop -->
      <div id="mobile-menu-overlay" class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm z-[110] hidden opacity-0 transition-opacity duration-300"></div>

      <!-- Mobile Menu Sidebar -->
      <div id="mobile-menu" class="fixed top-0 right-0 w-[75%] max-w-[280px] h-full bg-white z-[120] shadow-2xl transform translate-x-full invisible transition-all duration-300 ease-in-out p-6 flex flex-col">
        <div class="flex justify-between items-center mb-8">
          <span class="text-[10px] font-black uppercase tracking-[0.2em] text-blue-600">Navigasi</span>
          <button id="close-menu-button" class="text-slate-900 p-1.5 hover:bg-slate-50 rounded-full transition-colors" aria-label="Close Menu">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-x"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
          </button>
        </div>
        
        <nav class="flex flex-col space-y-3">
          <a href="/" class="mobile-nav-link flex items-center justify-between text-base font-bold text-slate-900 bg-slate-50/50 p-4 rounded-xl border border-transparent hover:border-blue-100 transition-all active:scale-[0.98]">
            <span>Beranda</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-600"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          </a>
          <a href="/portofolio/" class="mobile-nav-link flex items-center justify-between text-base font-bold text-slate-900 bg-slate-50/50 p-4 rounded-xl border border-transparent hover:border-blue-100 transition-all active:scale-[0.98]">
            <span>Portofolio</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-600"><rect width="20" height="14" x="2" y="7" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
          </a>
          <a href="/#layanan" class="mobile-nav-link flex items-center justify-between text-base font-bold text-slate-900 bg-slate-50/50 p-4 rounded-xl border border-transparent hover:border-blue-100 transition-all active:scale-[0.98]">
            <span>Layanan</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-600"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 2.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-5c1.62-2.2 5-3 5-3"/><path d="M12 15v5s3.03-.55 5-2c2.2-1.62 3-5 3-5"/></svg>
          </a>
          
          <div class="pt-6">
            <a href={`https://wa.me/${WHATSAPP_NUMBER}`} class="flex items-center justify-center w-full bg-blue-600 text-white py-4 rounded-xl font-bold shadow-xl shadow-blue-200 active:scale-95 transition-all text-base">
               <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mr-2"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/></svg> Chat WhatsApp
            </a>
          </div>
        </nav>

        <div class="mt-auto pt-8 text-center border-t border-slate-50">
          <PerformanceBadge class="mb-4" />
          <p class="text-[9px] text-slate-400 font-bold uppercase tracking-widest leading-relaxed">
            {SITE_NAME}<br />Partner Digital Brebes & Tegal
          </p>
        </div>
      </div>
    </header>

    <script>
      function initLucide() {
        if (typeof (window as any).lucide !== 'undefined') {
          (window as any).lucide.createIcons();
        } else {
          setTimeout(initLucide, 100);
        }
      }

      document.addEventListener('astro:page-load', () => {
        initLucide();

        const menuBtn = document.getElementById('mobile-menu-button');
        const closeBtn = document.getElementById('close-menu-button');
        const menu = document.getElementById('mobile-menu');
        const overlay = document.getElementById('mobile-menu-overlay');
        const links = document.querySelectorAll('.mobile-nav-link');

        if (!menu || !overlay) return;

        function openMenu() {
          menu?.classList.remove('invisible');
          overlay?.classList.remove('hidden');
          // Trigger reflow
          void overlay?.offsetWidth;
          overlay?.classList.remove('opacity-0');
          menu?.classList.remove('translate-x-full');
          document.body.style.overflow = 'hidden';
        }

        function closeMenu() {
          menu?.classList.add('translate-x-full');
          overlay?.classList.add('opacity-0');
          setTimeout(() => {
            overlay?.classList.add('hidden');
            menu?.classList.add('invisible');
          }, 300);
          document.body.style.overflow = '';
        }

        if (menuBtn) menuBtn.onclick = openMenu;
        if (closeBtn) closeBtn.onclick = closeMenu;
        if (overlay) overlay.onclick = closeMenu;
        
        links.forEach(link => {
          (link as HTMLElement).onclick = () => {
            setTimeout(closeMenu, 150);
          };
        });

        // Intersection Observer
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('active');
            }
          });
        }, { threshold: 0.1 });

        document.querySelectorAll('section').forEach(el => {
          el.classList.add('reveal');
          observer.observe(el);
        });
      });
    </script>

    <main>
      <slot />
    </main>

    <footer class="bg-slate-900 text-slate-300 py-12">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
          <div>
            <h2 class="text-white text-xl font-bold mb-4">{SITE_NAME}</h2>
            <p class="text-sm leading-relaxed mb-6">
              {SITE_DESCRIPTION}
            </p>
            <PerformanceBadge />
          </div>
          <div>
            <h3 class="text-white font-semibold mb-4">Layanan Kami</h3>
            <ul class="space-y-2 text-sm">
              <li>Jasa Website Kustom</li>
              <li>IoT Development</li>
              <li>Sistem Informasi Enterprise</li>
              <li>Optimasi SEO Lokal</li>
            </ul>
          </div>
          <div>
            <h3 class="text-white font-semibold mb-4">Wilayah Layanan</h3>
            <p class="text-sm">Melayani seluruh wilayah Brebes, Bumiayu, Tegal, Slawi, dan sekitarnya secara profesional.</p>
          </div>
        </div>
        <div class="border-t border-slate-800 mt-12 pt-8 text-center text-xs">
          <p>&copy; {new Date().getFullYear()} {SITE_NAME}. Seluruh hak cipta dilindungi.</p>
        </div>
      </div>
    </footer>
  </body>
</html>
