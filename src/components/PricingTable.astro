---
const comparisons = [
  { label: "Cocok Untuk", starter: "Bisnis Perorangan", business: "Perusahaan / UKM", icon: "user" },
  { label: "Email Bisnis", starter: "❌ Tidak Ada", business: "✅ Profesional", icon: "mail" },
  { label: "Optimasi Google", starter: "Dasar", business: "Prioritas Maps", icon: "search" },
  { label: "Jumlah Halaman", starter: "1 Halaman", business: "Hingga 5 Hal", icon: "layers" },
  { label: "Biaya Hosting", starter: "Rp 0", business: "Rp 0", icon: "database" },
  { label: "Kecepatan", starter: "Sangat Cepat", business: "Ultra Cepat", icon: "zap" }
];
---

<div class="mt-24 relative px-4">
  <div class="text-center mb-12">
    <h3 class="text-2xl md:text-3xl font-bold text-slate-900 mb-2">Detail Perbandingan Fitur</h3>
    <p class="text-slate-500 text-sm">Transparansi penuh untuk membantu Anda mengambil keputusan terbaik.</p>
  </div>

  <div class="max-w-4xl mx-auto bg-white rounded-[2rem] shadow-2xl shadow-blue-100/50 border border-blue-50 overflow-hidden">
    <!-- Header Grid -->
    <div class="grid grid-cols-2 md:grid-cols-3 bg-slate-900 text-white border-b border-slate-800">
      <div class="hidden md:flex p-6 text-xs font-black uppercase tracking-widest text-slate-400 items-center">Fitur Utama</div>
      <div class="p-6 text-xs font-black uppercase tracking-widest text-center border-l border-slate-800 flex flex-col gap-1 items-center justify-center">
        <span class="text-[10px] text-blue-400">Paket</span>
        <span class="text-sm">Starter</span>
      </div>
      <div class="p-6 text-xs font-black uppercase tracking-widest text-center border-l border-slate-800 bg-blue-600 flex flex-col gap-1 items-center justify-center">
        <span class="text-[10px] text-blue-100">Paket</span>
        <span class="text-sm">Business</span>
      </div>
    </div>

    <!-- Table Body -->
    <div class="bg-white border-x border-b border-slate-200 rounded-b-[2rem] shadow-2xl overflow-hidden">
      {comparisons.map((row, i) => (
        <div class:list={[
          "grid grid-cols-2 md:grid-cols-3 border-t border-slate-100 transition-all hover:bg-blue-50/20 group",
          i === 0 ? "md:border-t-0" : ""
        ]}>
          <!-- Feature Label (Desktop) -->
          <div class="hidden md:flex p-6 items-center gap-4 bg-slate-50/30">
            <div class="w-10 h-10 rounded-xl bg-white shadow-sm text-blue-600 flex items-center justify-center group-hover:scale-110 group-hover:rotate-3 transition-all duration-300 border border-slate-100">
              <span data-lucide={row.icon} class="w-5 h-5"></span>
            </div>
            <span class="font-bold text-slate-800 text-sm">{row.label}</span>
          </div>

          <!-- Starter Value -->
          <div class="p-6 md:p-8 text-center border-l md:border-l border-slate-100 flex flex-col items-center justify-center gap-2 not-italic">
            <span class="md:hidden text-[10px] font-black uppercase tracking-widest text-slate-400">Starter</span>
            <div class="md:hidden w-8 h-8 rounded-lg bg-slate-50 text-slate-400 flex items-center justify-center mb-2">
              <span data-lucide={row.icon} class="w-4 h-4"></span>
            </div>
            <span class="text-slate-600 text-sm md:text-base font-medium">{row.starter}</span>
          </div>

          <!-- Business Value -->
          <div class="p-6 md:p-8 text-center border-l border-slate-100 bg-blue-50/10 flex flex-col items-center justify-center gap-2 relative not-italic">
            <span class="md:hidden text-[10px] font-black uppercase tracking-widest text-blue-500">Business</span>
            <div class="md:hidden w-8 h-8 rounded-lg bg-blue-100 text-blue-600 flex items-center justify-center mb-2">
              <span data-lucide={row.icon} class="w-4 h-4"></span>
            </div>
            <span class="text-blue-900 text-sm md:text-base font-bold">{row.business}</span>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Footnote -->
  <div class="max-w-4xl mx-auto mt-8 flex items-center justify-center gap-2 text-slate-400 not-italic text-[10px] md:text-xs">
    <span data-lucide="help-circle" class="w-3 h-3"></span>
    <span>Investasi ini dirancang untuk ROI bisnis jangka panjang di ekosistem digital.</span>
  </div>

  <!-- Decorative -->
  <div class="absolute -top-20 -right-20 w-64 h-64 bg-blue-100 rounded-full blur-[100px] opacity-20 -z-10"></div>
</div>
