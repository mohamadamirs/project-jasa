---
import PricingCarousel from './react/PricingCarousel';
---

<div class="mt-16 md:mt-24 relative px-4 overflow-hidden">
  <div class="text-center mb-8">
    <h3 class="text-3xl md:text-4xl font-extrabold text-slate-900 mb-3 tracking-tight">Pilih Tingkat <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-indigo-600">Performa</span> Anda</h3>
    <p class="text-slate-500 text-sm md:text-base max-w-lg mx-auto">Geser atau arahkan kursor ke kartu untuk membandingkan fitur eksklusif dari masing-masing paket.</p>
  </div>

  <PricingCarousel client:visible />
</div>
