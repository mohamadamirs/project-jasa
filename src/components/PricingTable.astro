---
const plans = [
  {
    name: "Starter",
    subtitle: "Bisnis Perorangan",
    price: "250rb",
    features: [
      { label: "Email Bisnis", value: "Tidak Ada", icon: "minus", active: false },
      { label: "Optimasi Google", value: "Dasar", icon: "search", active: true },
      { label: "Jumlah Halaman", value: "1 Halaman", icon: "layers", active: true },
      { label: "Sistem Kustom", value: "Tidak Ada", icon: "minus", active: false },
      { label: "Biaya Hosting", value: "Rp 0", icon: "database", active: true },
      { label: "Kecepatan", value: "Sangat Cepat", icon: "zap", active: true }
    ],
    bg: "bg-slate-50",
    border: "border-slate-200",
    text: "text-slate-600"
  },
  {
    name: "Business",
    subtitle: "Perusahaan / UKM",
    price: "1.8jt",
    recommended: true,
    features: [
      { label: "Email Bisnis", value: "Profesional", icon: "mail", active: true },
      { label: "Optimasi Google", value: "Prioritas Maps", icon: "search", active: true },
      { label: "Jumlah Halaman", value: "Hingga 5 Hal", icon: "layers", active: true },
      { label: "Sistem Kustom", value: "Tidak Ada", icon: "minus", active: false },
      { label: "Biaya Hosting", value: "Rp 0", icon: "database", active: true },
      { label: "Kecepatan", value: "Ultra Cepat", icon: "zap", active: true }
    ],
    bg: "bg-blue-600",
    border: "border-blue-500",
    text: "text-blue-100"
  },
  {
    name: "Custom",
    subtitle: "Skala Enterprise",
    price: "Hubungi",
    features: [
      { label: "Email Bisnis", value: "Profesional", icon: "mail", active: true },
      { label: "Optimasi Google", value: "Dominasi Nasional", icon: "search", active: true },
      { label: "Jumlah Halaman", value: "Tidak Terbatas", icon: "layers", active: true },
      { label: "Sistem Kustom", value: "Sistem & IoT", icon: "code", active: true },
      { label: "Biaya Hosting", value: "Rp 0", icon: "database", active: true },
      { label: "Kecepatan", value: "Ultra Cepat", icon: "zap", active: true }
    ],
    bg: "bg-slate-900",
    border: "border-slate-800",
    text: "text-slate-400"
  }
];
---

<div class="mt-24 relative px-4">
  <div class="text-center mb-8 md:mb-12">
    <h3 class="text-2xl md:text-3xl font-bold text-slate-900 mb-2">Bandingkan Detail Fitur</h3>
    <p class="text-slate-500 text-sm">Pilih spesifikasi teknis yang paling sesuai dengan target Anda.</p>
  </div>

  <!-- Mobile Swipe Indicator -->
  <div class="md:hidden flex items-center justify-center gap-2 mb-6 text-blue-600 animate-pulse">
    <span data-lucide="hand" class="w-4 h-4"></span>
    <span class="text-xs font-bold uppercase tracking-widest">Geser Kartu</span>
    <span data-lucide="arrow-right" class="w-4 h-4"></span>
  </div>

  <div class="max-w-6xl mx-auto">
    <!-- Comparison Cards Container -->
    <div id="comparison-slider" class="flex md:grid md:grid-cols-3 gap-4 md:gap-8 overflow-x-auto snap-x snap-mandatory no-scrollbar pb-8 px-4 md:px-0 -mx-4 md:mx-0">
      
      {plans.map((plan, i) => (
        <div class:list={[
          "comparison-card shrink-0 w-[85vw] sm:w-[320px] md:w-auto snap-center rounded-3xl border shadow-xl transition-all duration-500 flex flex-col relative",
          plan.recommended ? "border-blue-600 shadow-blue-200 md:scale-105 z-10" : "border-slate-100 shadow-slate-200 opacity-50 scale-90 md:opacity-100 md:scale-100",
          plan.name === "Starter" ? "bg-white" : plan.name === "Business" ? "bg-blue-600 text-white" : "bg-slate-900 text-white"
        ]} data-index={i}>
          
          {plan.recommended && (
            <div class="absolute -top-4 left-1/2 -translate-x-1/2">
              <span class="bg-gradient-to-r from-blue-400 to-blue-600 text-white text-[10px] font-black uppercase tracking-widest px-4 py-1.5 rounded-full shadow-lg whitespace-nowrap">
                Rekomendasi
              </span>
            </div>
          )}

          <!-- Card Header -->
          <div class:list={[
            "p-6 md:p-8 text-center border-b",
            plan.name === "Starter" ? "border-slate-100" : plan.name === "Business" ? "border-blue-500" : "border-slate-800"
          ]}>
            <span class:list={[
              "text-[10px] font-black uppercase tracking-widest mb-2 block",
              plan.name === "Starter" ? "text-slate-400" : plan.name === "Business" ? "text-blue-200" : "text-slate-500"
            ]}>{plan.subtitle}</span>
            <h4 class="text-2xl md:text-3xl font-black mb-1">{plan.name}</h4>
            <div class:list={[
              "inline-block px-3 py-1 rounded-lg text-sm font-bold mt-2",
              plan.name === "Starter" ? "bg-slate-100 text-slate-700" : plan.name === "Business" ? "bg-blue-700 text-white" : "bg-slate-800 text-slate-300"
            ]}>
              {plan.price}
            </div>
          </div>

          <!-- Card Body / Features -->
          <div class="p-6 md:p-8 flex-grow">
            <ul class="space-y-4">
              {plan.features.map((feature) => (
                <li class="flex items-center gap-3">
                  <div class:list={[
                    "w-8 h-8 rounded-full flex items-center justify-center shrink-0 transition-colors",
                    feature.active 
                      ? (plan.name === "Starter" ? "bg-blue-50 text-blue-600" : plan.name === "Business" ? "bg-blue-500 text-white" : "bg-slate-800 text-white")
                      : (plan.name === "Starter" ? "bg-slate-50 text-slate-300" : plan.name === "Business" ? "bg-blue-700 text-blue-400" : "bg-slate-800/50 text-slate-600")
                  ]}>
                    <span data-lucide={feature.icon} class="w-4 h-4"></span>
                  </div>
                  <div>
                    <span class:list={[
                      "block text-[10px] uppercase tracking-wider font-bold mb-0.5",
                      plan.name === "Starter" ? "text-slate-400" : plan.name === "Business" ? "text-blue-200" : "text-slate-500"
                    ]}>{feature.label}</span>
                    <span class:list={[
                      "block text-sm md:text-base font-medium",
                      plan.name === "Starter" ? "text-slate-700" : plan.name === "Business" ? "text-white" : "text-slate-300",
                      !feature.active && "line-through opacity-50"
                    ]}>{feature.value}</span>
                  </div>
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
      
    </div>
  </div>

  <!-- Script for Intersection Observer (Zoom in/out effect on Mobile) -->
  <script>
    document.addEventListener('astro:page-load', () => {
      const slider = document.getElementById('comparison-slider');
      const cards = document.querySelectorAll('.comparison-card');
      
      if (!slider || cards.length === 0) return;

      const checkMobile = () => window.innerWidth < 768;
      let observer = null;

      const setupObserver = () => {
        if (checkMobile()) {
          if (observer) return; // Already setup
          
          observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
              const card = entry.target;
              if (entry.isIntersecting) {
                card.classList.remove('scale-90', 'opacity-50');
                card.classList.add('scale-100', 'opacity-100');
              } else {
                card.classList.remove('scale-100', 'opacity-100');
                card.classList.add('scale-90', 'opacity-50');
              }
            });
          }, {
            root: slider,
            threshold: 0.6
          });

          cards.forEach(card => observer.observe(card));

          // Scroll to the middle card on load
          setTimeout(() => {
            const middleCard = cards[1];
            if (middleCard) {
              slider.scrollTo({
                left: middleCard.offsetLeft - (slider.clientWidth / 2) + (middleCard.clientWidth / 2),
                behavior: 'smooth'
              });
            }
          }, 300);
        } else {
          // Desktop: remove observer and classes
          if (observer) {
            observer.disconnect();
            observer = null;
          }
          cards.forEach(card => {
            card.classList.remove('scale-90', 'opacity-50', 'scale-100', 'opacity-100');
          });
        }
      };

      setupObserver();
      window.addEventListener('resize', setupObserver);
    });
  </script>
</div>
