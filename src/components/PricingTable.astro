---
import PricingCarousel from './react/PricingCarousel';
import SectionHeader from './SectionHeader.astro';

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<section id="harga" class:list={["section-spacing bg-white relative overflow-hidden", className]}>
  <div class="container-custom relative z-10">
    <!-- Abstract Decorative Blobs -->
    <div class="absolute top-1/4 left-0 -translate-x-1/2 w-[clamp(20rem,40vw,30rem)] aspect-square bg-blue-600/5 rounded-full blur-[100px] opacity-60 pointer-events-none"></div>
    
    <SectionHeader 
      preTitle="Investasi"
      title="Paket <span class='text-blue-600'>Harga</span>" 
      subtitle="Pilih paket yang paling sesuai dengan skala bisnis Anda. Harga transparan, fitur lengkap, dan tanpa biaya tersembunyi." 
    />

    <div class="relative z-10">
      <PricingCarousel client:visible />
    </div>
  </div>
</section>
