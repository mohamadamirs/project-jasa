---
import PricingCarousel from './react/PricingCarousel';
---

<div class="mt-12 md:mt-20 relative overflow-hidden">
  <!-- Abstract Decorative Blobs for Glassmorphism Effect -->
  <div class="absolute top-1/4 left-0 -translate-x-1/2 w-[clamp(20rem,40vw,30rem)] aspect-square bg-blue-600/5 rounded-full blur-[100px] opacity-60 pointer-events-none"></div>
  <div class="absolute bottom-0 right-0 translate-x-1/3 w-[clamp(15rem,35vw,25rem)] aspect-square bg-indigo-100 rounded-full blur-[100px] opacity-50 pointer-events-none"></div>

  <div class="text-center mb-[clamp(2rem,6vh,4rem)] relative z-10">
    <h2 class="mb-3 tracking-tight">Paket <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-indigo-700">Harga</span></h2>
    <p class="text-slate-500 max-w-lg mx-auto">Pilih paket yang paling sesuai dengan skala bisnis Anda. Harga transparan, fitur lengkap, dan tanpa biaya tersembunyi.</p>
  </div>

  <div class="relative z-10">
    <PricingCarousel client:visible />
  </div>
</div>
