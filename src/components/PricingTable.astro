---
import PricingCarousel from './react/PricingCarousel';
---

<div class="mt-16 md:mt-24 relative px-4 overflow-hidden">
  <div class="text-center mb-8">
    <h3 class="text-3xl md:text-4xl font-extrabold text-slate-900 mb-3 tracking-tight">Paket <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-indigo-600">Investasi Digital</span> Anda</h3>
    <p class="text-slate-500 text-sm md:text-base max-w-lg mx-auto">Pilih paket yang paling sesuai dengan skala bisnis Anda. Harga transparan, fitur lengkap, dan tanpa biaya tersembunyi.</p>
  </div>

  <PricingCarousel client:visible />
</div>
