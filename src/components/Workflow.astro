---
import SectionHeader from './SectionHeader.astro';

const steps = [
  { step: "01", t: "Konsultasi", d: "Diskusi kebutuhan bisnis Anda secara detail.", i: "search" },
  { step: "02", t: "Desain", d: "Pembuatan konsep visual yang modern.", i: "layout" },
  { step: "03", t: "Development", d: "Proses pengkodean dan optimasi SEO.", i: "code-2" },
  { step: "04", t: "Launch", d: "Website online dan siap menerima pelanggan.", i: "rocket" }
];
---

<section id="proses" class="py-12 md:py-24 bg-sky-50 border-y border-blue-100 overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <SectionHeader 
      title={`Alur Kerja <span class="text-blue-600">Mudah</span>`} 
      subtitle="Proses transparan untuk memastikan hasil terbaik bagi bisnis Anda." 
    />
    
    <div class="flex flex-row md:grid md:grid-cols-4 gap-2 md:gap-8 relative mt-12 overflow-x-auto pb-4 md:pb-0 scroll-smooth snap-x snap-mandatory no-scrollbar">
      <!-- Connector Line (Desktop Only) -->
      <div class="hidden md:block absolute top-8 left-0 w-full h-0.5 bg-blue-100 -z-0"></div>

      {steps.map(step => (
        <div class="flex-none w-[120px] md:w-auto relative group z-10 snap-center">
          <div class="w-10 h-10 md:w-16 md:h-16 bg-blue-600 text-white rounded-xl md:rounded-2xl flex items-center justify-center mx-auto mb-3 md:mb-6 shadow-md shadow-blue-200 group-hover:rotate-6 transition-transform hover-lift active:scale-95">
            <span data-lucide={step.i} class="w-5 h-5 md:w-8 md:h-8"></span>
          </div>
          <h4 class="font-bold text-slate-900 mb-1 text-[10px] md:text-base leading-tight uppercase tracking-tighter md:normal-case md:tracking-normal">{step.t}</h4>
          <p class="text-slate-500 text-[8px] md:text-sm leading-tight md:leading-relaxed px-1 md:px-0">{step.d}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>
