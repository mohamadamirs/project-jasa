---
import SectionHeader from './SectionHeader.astro';
import { WorkflowSlider } from './react/WorkflowSlider';

const steps = [
  { step: "01", t: "Konsultasi", d: "Diskusi kebutuhan bisnis Anda secara detail.", i: "search" },
  { step: "02", t: "Desain", d: "Pembuatan konsep visual yang modern.", i: "layout" },
  { step: "03", t: "Development", d: "Proses pengkodean dan optimasi SEO.", i: "code-2" },
  { step: "04", t: "Launch", d: "Website online dan siap menerima pelanggan.", i: "rocket" }
];
---

<section id="proses" class="section-spacing bg-slate-50/50 border-y border-blue-600/10 overflow-hidden">
  <div class="container-custom text-center">
    <SectionHeader 
      title={`Alur Kerja <span class="text-blue-600">Mudah</span>`} 
      subtitle="Proses transparan untuk memastikan hasil terbaik bagi bisnis Anda." 
    />
    
    <!-- Desktop View (Premium Grid) -->
    <div class="hidden md:grid md:grid-cols-4 gap-8 relative mt-12">
      <!-- Connector Line -->
      <div class="absolute top-12 left-0 w-full h-0.5 bg-blue-600/10 -z-0"></div>

      {steps.map((step) => (
        <div class="relative group z-10">
          <div class="relative">
            <div class="w-20 h-20 md:w-24 md:h-24 bg-white border-2 border-blue-600/5 text-blue-600 rounded-[2rem] flex items-center justify-center mx-auto mb-6 md:mb-8 shadow-xl shadow-blue-600/5 group-hover:bg-blue-600 group-hover:text-white group-hover:rotate-6 transition-all duration-500 hover-lift active:scale-95">
              <span data-lucide={step.i} class="w-10 h-10 md:w-12 md:h-12"></span>
            </div>
          </div>
          
          <h3 class="mb-3 md:mb-4 text-xl md:text-2xl font-bold tracking-tight">{step.t}</h3>
          <p class="text-slate-500 px-4 md:px-0 text-balance text-sm md:text-base leading-relaxed">{step.d}</p>
          
          <!-- Large Background Step Counter -->
          <div class="mt-6 text-[4rem] font-black text-blue-600/5 leading-none select-none">
            {step.step}
          </div>
        </div>
      ))}
    </div>

    <!-- Mobile View (Premium React Slider) -->
    <div class="md:hidden -mx-4">
      <WorkflowSlider client:visible />
    </div>
  </div>
</section>

<style>
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>
