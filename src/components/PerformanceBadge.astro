---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div class:list={["inline-flex items-center gap-2.5 px-4 py-2 bg-blue-600/5 text-blue-600 border border-blue-600/10 rounded-full text-caption shadow-sm shadow-blue-600/5", className]}>
  <div class="flex items-center justify-center w-6 h-6 bg-blue-600 text-white rounded-full text-[10px] font-black">100</div>
  <span class="normal-case tracking-normal">Audit Performa Google</span>
  <div class="group relative flex items-center">
    <span data-lucide="info" class="w-4 h-4 text-blue-400 cursor-help"></span>
    <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 w-48 p-2 bg-slate-900 text-white text-[10px] rounded-lg opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none text-center shadow-xl z-50 font-medium normal-case tracking-normal">
      Skor 100/100 menjamin loading instan yang sangat disukai Google & pelanggan Anda.
      <div class="absolute top-full left-1/2 -translate-x-1/2 border-8 border-transparent border-t-slate-900"></div>
    </div>
  </div>
</div>
