---
import { SITE_NAME } from '../consts';

interface Props {
  class?: string;
}

const { class: className } = Astro.props;

const clients = ['Resto Lokal', 'Toko Bangunan', 'Logistik Brebes', 'Pabrik Bawang', 'Agro Bisnis'];
// Duplikasi list agar scroll tidak terputus
const doubledClients = [...clients, ...clients];
---

<section class:list={["section-spacing bg-white border-y border-slate-100 overflow-hidden", className]}>
  <div class="container-custom">
    <p class="text-center text-caption text-slate-500 mb-12">Telah Dipercaya Oleh Bisnis Lokal</p>
    
    <div class="relative">
      <div class="animate-infinite-scroll gap-12 md:gap-24 items-center opacity-60">
        {doubledClients.map((klien) => (
          <div class="flex items-center gap-3 group cursor-default h-10 not-italic shrink-0">
            <div class="w-6 h-6 flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-slate-400 group-hover:text-blue-600 transition-colors"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
            </div>
            <span class="text-[clamp(1.1rem,2.5vw,1.5rem)] font-black text-slate-900 tracking-tighter uppercase whitespace-nowrap italic-none">{klien}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
