---
interface Props {
  title: string;
  subtitle?: string;
  align?: 'center' | 'left';
  class?: string;
}

const { title, subtitle, align = 'center', class: className } = Astro.props;
---

<div class:list={[
  "mb-[clamp(2.5rem,8vh,4.5rem)]",
  align === 'center' ? "text-center" : "text-left",
  className
]}>
  <h2 class:list={["mb-4 px-1", align === 'center' ? "mx-auto" : ""]} set:html={title} />
  {subtitle && <p class:list={["text-slate-600 max-w-2xl", align === 'center' ? "mx-auto" : ""]}>{subtitle}</p>}
</div>
