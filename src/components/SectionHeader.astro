---
interface Props {
  title: string;
  preTitle?: string;
  subtitle?: string;
  align?: 'center' | 'left';
  class?: string;
}

const { title, preTitle, subtitle, align = 'center', class: className } = Astro.props;
---

<div class:list={[
  "mb-[clamp(2.5rem,8vh,4.5rem)]",
  align === 'center' ? "text-center" : "text-left",
  className
]}>
  {preTitle && (
    <div class:list={[
      "flex items-center gap-3 mb-4 text-[10px] md:text-xs font-black uppercase tracking-[0.3em] text-blue-600/60",
      align === 'center' ? "justify-center" : "justify-start"
    ]}>
      <span class="w-8 h-px bg-blue-600/30"></span>
      {preTitle}
    </div>
  )}
  
  <div class="relative inline-block">
    <h2 class:list={["mb-4 px-1", align === 'center' ? "mx-auto" : ""]} set:html={title} />
    {align === 'center' && (
      <div class="absolute -bottom-1 left-1/2 -translate-x-1/2 w-12 h-1 bg-gradient-to-r from-blue-600 to-indigo-600 rounded-full opacity-20"></div>
    )}
  </div>

  {subtitle && <p class:list={["text-slate-600 max-w-2xl mt-4", align === 'center' ? "mx-auto" : ""]}>{subtitle}</p>}
</div>
