---
import ImageSliderReact from './react/ImageSlider';

interface Props {
  images: any[];
}

const { images = [] } = Astro.props;

// Kita konversi metadata gambar Astro ke string src untuk dikirim ke React
// Di Astro 5+, metadata gambar memiliki properti .src
const imageSources = images.map(img => typeof img === 'string' ? img : img.src);
---

<ImageSliderReact images={imageSources} client:visible />
