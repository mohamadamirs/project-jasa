---
import SectionHeader from './SectionHeader.astro';

interface Area {
  id: string;
  data: {
    cityName: string;
  };
}

interface Props {
  areas: Area[];
  title?: string;
  subtitle?: string;
  class?: string;
}

const { 
  areas, 
  title = "Kami Hadir di Dekat Anda", 
  subtitle = "Klik wilayah Anda untuk melihat penawaran khusus dan konsultasi personal.",
  class: className 
} = Astro.props;
---

<section class:list={["py-12 md:py-24 bg-white", className]}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto mb-12">
      <SectionHeader {title} {subtitle} align="center" />
    </div>

    <div class="grid grid-cols-2 md:grid-cols-5 gap-3 md:gap-4">
      {areas.map((area) => (
        <a href={`/${area.id}/`} class="group p-5 md:p-8 bg-white rounded-3xl border border-slate-100 hover:bg-blue-600 transition-all duration-500 ease-out text-center hover:shadow-xl hover:shadow-blue-200 hover-lift active:scale-95 flex flex-col items-center justify-center min-h-[120px] md:min-h-[160px]">
          <span class="block text-slate-900 font-bold group-hover:text-white transition-colors duration-300 text-sm md:text-lg leading-tight not-italic italic-none">{area.data.cityName}</span>
          <span class="text-[10px] md:text-xs uppercase tracking-[0.2em] text-slate-400 group-hover:text-blue-100 transition-colors duration-300 flex items-center justify-center mt-4 font-black not-italic">
            Detail <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="ml-2"><path d="m9 18 6-6-6-6"/></svg>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
