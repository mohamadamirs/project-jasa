---
import SectionHeader from './SectionHeader.astro';

interface FAQItem {
  q: string;
  a: string;
}

interface Props {
  title?: string;
  items: FAQItem[];
  class?: string;
}

const { 
  title = "Tanya Jawab <span class='text-blue-600'>Umum</span>", 
  items,
  class: className 
} = Astro.props;
---

<section class:list={["section-spacing bg-slate-50/50", className]}>
  <div class="max-w-4xl mx-auto container-custom">
    <SectionHeader pretitle="FAQ" {title} />
    <div class="space-y-4">
      {items.map((faq) => (
        <div class="card-standard card-padding-fluid text-left border-blue-600/10 hover:shadow-xl hover:shadow-blue-600/5 transition-all group">
          <h4 class="font-bold text-slate-900 mb-4 flex items-start md:items-center group-hover:text-blue-600 transition-colors">
            <span data-lucide="help-circle" class="text-blue-600 mr-3 w-6 h-6 flex-shrink-0"></span> {faq.q}
          </h4>
          <p class="text-slate-600 pl-9 leading-relaxed">{faq.a}</p>
        </div>
      ))}
    </div>
  </div>
</section>
