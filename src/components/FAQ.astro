---
import SectionHeader from './SectionHeader.astro';

interface FAQItem {
  q: string;
  a: string;
}

interface Props {
  title?: string;
  items: FAQItem[];
  class?: string;
}

const { 
  title = "Tanya Jawab <span class='text-blue-600'>Umum</span>", 
  items,
  class: className 
} = Astro.props;
---

<section class:list={["py-12 md:py-24 bg-sky-50", className]}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <SectionHeader {title} />
    <div class="space-y-3 md:space-y-4">
      {items.map((faq) => (
        <div class="bg-white p-5 md:p-6 rounded-2xl border border-blue-100 text-left hover:shadow-md transition-shadow group">
          <h4 class="font-bold text-slate-900 mb-2 flex items-start md:items-center text-sm md:text-base group-hover:text-blue-600 transition-colors">
            <span data-lucide="help-circle" class="text-blue-600 mr-3 w-5 h-5 flex-shrink-0"></span> {faq.q}
          </h4>
          <p class="text-slate-600 text-xs md:text-sm pl-8 leading-relaxed">{faq.a}</p>
        </div>
      ))}
    </div>
  </div>
</section>
