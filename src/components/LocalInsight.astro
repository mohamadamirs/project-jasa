---
import WhatsAppCTA from './WhatsAppCTA.astro';

interface Props {
  cityName: string;
  localContext: string;
  localLandmark: string;
  businessTrends: string;
  clientCountLocal: number;
}

const { cityName, localContext, localLandmark, businessTrends, clientCountLocal } = Astro.props;
---

<section class="py-12 md:py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="bg-white rounded-3xl p-5 md:p-16 shadow-sm border border-slate-100">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center text-center lg:text-left">
        <div>
          <h2 class="font-bold text-slate-900 mb-6 text-balance">Peluang Bisnis Digital di {cityName}</h2>
          <p class="text-slate-600 mb-6 text-sm md:text-base leading-relaxed">
            {localContext} Terutama dengan adanya landmark <span class="font-bold text-slate-900">{localLandmark}</span>, tren <span class="italic text-blue-600">{businessTrends}</span> di {cityName} kini semakin meningkat. Kami telah membantu {clientCountLocal}+ klien di area ini untuk go-digital.
          </p>
          <ul class="space-y-4 mb-8 lg:mb-0">
            {["Dominasi hasil pencarian lokal " + cityName, "Meningkatkan Kepercayaan Pelanggan", "Sistem booking atau pemesanan otomatis"].map((item) => (
              <li class="flex items-start md:items-center text-slate-700 font-medium text-sm md:text-base not-italic">
                <span data-lucide="check-circle-2" class="text-blue-600 mr-3 w-6 h-6 flex-shrink-0"></span> 
                <span class="text-left">{item}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="bg-blue-600 rounded-3xl p-6 md:p-10 text-white relative overflow-hidden group shine-effect shadow-2xl shadow-blue-200">
          <h3 class="text-xl md:text-2xl font-bold mb-4 relative z-10 leading-tight text-balance">Penawaran Khusus UMKM {cityName}</h3>
          <p class="mb-8 text-blue-100 text-xs md:text-sm relative z-10 underline decoration-blue-400">Dapatkan diskon khusus untuk UMKM yang berdomisili di {cityName} dan sekitarnya.</p>
          <div class="text-4xl md:text-5xl font-black mb-8 relative z-10 tracking-tighter">Mulai Rp 250rb</div>
          <div class="relative z-10">
            <WhatsAppCTA message={`Halo, saya mau klaim promo wilayah ${cityName}`} label="Klaim Promo Sekarang" variant="white" class="w-full" />
          </div>
          <span data-lucide="award" class="absolute -bottom-10 -right-10 w-48 h-48 text-blue-500 opacity-20 group-hover:rotate-12 transition-transform"></span>
        </div>
      </div>
    </div>
  </div>
</section>
