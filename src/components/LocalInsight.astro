---
import WhatsAppCTA from './WhatsAppCTA.astro';

interface Props {
  cityName: string;
  localContext: string;
  localLandmark: string;
  businessTrends: string;
  clientCountLocal: number;
}

const { cityName, localContext, localLandmark, businessTrends, clientCountLocal } = Astro.props;
---

<section class="section-spacing bg-white">
  <div class="container-custom">
    <div class="card-standard card-padding-fluid shadow-sm border border-slate-100">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center text-center lg:text-left">
        <div>
          <h2 class="mb-6">Peluang Bisnis Digital di {cityName}</h2>
          <p class="text-slate-600 mb-6 leading-relaxed">
            {localContext} Terutama dengan adanya landmark <span class="font-bold text-slate-900">{localLandmark}</span>, tren <span class="italic text-blue-600">{businessTrends}</span> di {cityName} kini semakin meningkat. Kami telah membantu {clientCountLocal}+ klien di area ini untuk go-digital.
          </p>
          <ul class="space-y-4 mb-8 lg:mb-0">
            {["Dominasi hasil pencarian lokal " + cityName, "Meningkatkan Kepercayaan Pelanggan", "Sistem booking atau pemesanan otomatis"].map((item) => (
              <li class="flex items-start md:items-center text-slate-700 font-medium not-italic">
                <span data-lucide="check-circle-2" class="text-blue-600 mr-3 w-7 h-7 flex-shrink-0"></span> 
                <span class="text-left">{item}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="bg-blue-600 rounded-[clamp(1.25rem,5vw,2rem)] p-8 md:p-12 text-white relative overflow-hidden group shine-effect shadow-2xl shadow-blue-600/20">
          <h3 class="mb-4 relative z-10 tracking-tight">Penawaran Khusus UMKM {cityName}</h3>
          <p class="mb-8 text-white/90 text-caption relative z-10 underline decoration-blue-600/30">Dapatkan diskon khusus untuk UMKM yang berdomisili di {cityName} dan sekitarnya.</p>
          <div class="text-[clamp(2rem,8vw,3.5rem)] font-black mb-8 relative z-10 tracking-tighter">Mulai Rp 250rb</div>
          <div class="relative z-10">
            <WhatsAppCTA message={`Halo, saya mau klaim promo wilayah ${cityName}`} label="Klaim Promo Sekarang" variant="white" class="w-full" />
          </div>
          <span data-lucide="award" class="absolute -bottom-10 -right-10 w-48 h-48 text-white/10 group-hover:rotate-12 transition-transform"></span>
        </div>
      </div>
    </div>
  </div>
</section>
