---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import MainLayout from '../layouts/MainLayout.astro';
import WhatsAppCTA from '../components/WhatsAppCTA.astro';

const title = "Portofolio Kami - Kutabaru Web Agency";
const description = "Lihat daftar karya terbaik kami dalam pengembangan Website Kustom, IoT Development, dan SEO Lokal untuk berbagai klien bisnis.";

// MENGAMBIL DATA PORTFOLIOS
const portfolios = await getCollection('portfolios');
---

<MainLayout {title} {description}>
  <!-- Header Portofolio -->
  <section class="bg-white pt-[clamp(5rem,15vh,10rem)] pb-[clamp(3rem,8vh,6rem)] border-b border-slate-100">
    <div class="container-custom px-[clamp(1rem,5vw,2.5rem)] text-center">
      <h1 class="mb-6">
        Karya <span class="text-blue-600">Terbaik</span> Kami
      </h1>
      <p class="max-w-2xl mx-auto leading-relaxed">
        Kami telah membantu puluhan bisnis untuk bertransformasi digital melalui solusi kustom yang tepat sasaran dan berteknologi tinggi.
      </p>
    </div>
  </section>

  <!-- Gallery Grid -->
  <section class="section-spacing bg-slate-50/50">
    <div class="container-custom">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {portfolios.map((project) => (
          <a href={`/portofolio/${project.id}`} class="group card-standard overflow-hidden border-blue-600/10 hover:shadow-2xl hover:shadow-blue-600/10 transition-all duration-500 flex flex-col">
            <!-- Project Image Placeholder with Icon -->
            <div class="aspect-video bg-blue-600/5 flex items-center justify-center relative overflow-hidden">
              {project.data.images && project.data.images.length > 0 ? (
                <Image 
                  src={project.data.images[0]} 
                  alt={project.data.title} 
                  width={600} 
                  height={338} 
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" 
                />
              ) : (
                <span data-lucide="play" class="w-16 h-16 text-blue-600/20 group-hover:scale-110 group-hover:rotate-6 transition-transform duration-500"></span>
              )}
              <div class="absolute top-4 left-4">
                <span class="px-3 py-1 bg-white/90 backdrop-blur-sm text-blue-600 text-caption rounded-full border border-blue-600/10">
                  {project.data.category}
                </span>
              </div>
            </div>
            
            <div class="p-8 flex-grow">
              <h4 class="mb-4 group-hover:text-blue-600 transition-colors">{project.data.title}</h4>
              <p class="text-slate-600 mb-6 line-clamp-3">
                {project.data.description}
              </p>
              <div class="flex flex-wrap gap-2 mt-auto">
                {project.data.tech.map((t) => (
                  <span class="px-3 py-1 bg-blue-600/5 text-blue-600/70 text-caption rounded-lg border border-blue-600/5 lowercase tracking-normal font-medium">
                    {t}
                  </span>
                ))}
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section-spacing bg-white">
    <div class="container-custom text-center">
      <div class="max-w-3xl mx-auto">
        <h2 class="mb-8">Ingin Proyek Anda Ada di Sini?</h2>
        <p class="mb-12 leading-relaxed">
          Mari diskusikan visi Anda. Tim ahli kami siap mewujudkannya menjadi solusi teknologi yang solid dan berprofit tinggi.
        </p>
        <WhatsAppCTA label="Mulai Konsultasi Proyek" />
      </div>
    </div>
  </section>
</MainLayout>
