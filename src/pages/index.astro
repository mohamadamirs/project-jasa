---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import MainLayout from '../layouts/MainLayout.astro';
import WhatsAppCTA from '../components/WhatsAppCTA.astro';
import PricingTable from '../components/PricingTable.astro';
import SectionHeader from '../components/SectionHeader.astro';
import SocialProof from '../components/SocialProof.astro';
import FAQ from '../components/FAQ.astro';
import AreaGrid from '../components/AreaGrid.astro';
import Workflow from '../components/Workflow.astro';
import PerformanceBadge from '../components/PerformanceBadge.astro';
import ServicesSlider from '../components/react/ServicesSlider';
import { seededSpin } from '../utils/spintax';

// Ambil semua data wilayah untuk ditampilkan di daftar layanan
const areas = await getCollection('areas');
// Ambil portofolio terbaru untuk showcase
const allPortfolios = await getCollection('portfolios');
const latestProject = allPortfolios[0];

const title = "Kutabaru Web Agency - Jasa Pembuatan Website Profesional & SEO";
const description = "Solusi digital terpercaya untuk UMKM and Bisnis. Kami melayani jasa pembuatan website cepat, responsif, dan optimal untuk SEO di wilayah Brebes, Tegal, dan sekitarnya.";
---

<MainLayout {title} {description}>
  <!-- 1. Hero Branding Section (Premium & Clean) -->
  <section class="relative pt-[clamp(5rem,15vh,10rem)] pb-[clamp(4rem,10vh,8rem)] overflow-hidden bg-white px-[clamp(1rem,5vw,2.5rem)]">
    <!-- Sophisticated Backdrop -->
    <div class="absolute inset-0 z-0">
      <div class="absolute top-0 left-0 w-full h-full bg-[radial-gradient(circle_at_50%_-20%,rgba(37,99,235,0.1),rgba(255,255,255,0))]"></div>
      <!-- Subtle Pattern: Modern Dotted Grid -->
      <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(#2563eb 0.5px, transparent 0.5px); background-size: 24px 24px;"></div>
      <!-- Controlled Decorative Blobs -->
      <div class="absolute top-[-10%] right-[-10%] w-[clamp(20rem,40vw,40rem)] aspect-square bg-blue-600/5 rounded-full blur-[100px] opacity-60 animate-float"></div>
      <div class="absolute bottom-[-10%] left-[-10%] w-[clamp(15rem,30vw,30rem)] aspect-square bg-blue-600/5 rounded-full blur-[80px] opacity-50 animate-float-delayed"></div>
    </div>

    <div class="container-custom relative z-10">
      <div class="text-center max-w-5xl mx-auto">
        <div class="inline-flex items-center px-4 py-2 rounded-full text-caption bg-blue-600/10 backdrop-blur-sm text-blue-700 border border-blue-600/10 mb-8 md:mb-12 animate-reveal shadow-sm hover:border-blue-600/40 transition-colors cursor-default group/badge">
          <span class="flex h-3 w-3 rounded-full bg-blue-600 mr-3 animate-pulse group-hover/badge:scale-125 transition-transform"></span>
          {seededSpin("Partner Digital {Terpercaya|Andalan|Premium} #1 di Wilayah Brebes & Tegal", "global")}
        </div>
        
        <div class="relative group/hero">
          <h1 class="mb-8 md:mb-10 animate-reveal-delayed cursor-default">
            Bangun <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-indigo-700 hover:from-indigo-600 hover:to-blue-700 transition-all duration-500">Ekosistem Digital</span> <br class="hidden md:block" /> Premium untuk Bisnis Anda
          </h1>
          <!-- Decorative element that reacts to group hover -->
          <div class="absolute -top-6 -left-6 w-12 h-12 border-t-2 border-l-2 border-blue-600/20 rounded-tl-2xl opacity-0 group-hover/hero:opacity-100 group-hover/hero:-translate-x-2 group-hover/hero:-translate-y-2 transition-all duration-500 pointer-events-none"></div>
          <div class="absolute -bottom-6 -right-6 w-12 h-12 border-b-2 border-r-2 border-blue-600/20 rounded-br-2xl opacity-0 group-hover/hero:opacity-100 group-hover/hero:translate-x-2 group-hover/hero:translate-y-2 transition-all duration-500 pointer-events-none"></div>
        </div>

        <p class="mb-10 md:mb-14 max-w-3xl mx-auto opacity-0 animate-reveal-delayed-2">
          Kami membantu UMKM naik kelas dengan website performa tinggi yang dirancang khusus untuk mendominasi pasar lokal dan global.
        </p>
        
        <div class="flex flex-col sm:flex-row justify-center items-center gap-4 opacity-0 animate-reveal-delayed-3">
          <WhatsAppCTA label="Mulai Konsultasi Gratis" class="w-full sm:w-auto scale-105 hover-lift shine-effect shadow-2xl shadow-blue-600/20" />
          <a href="#layanan" class="w-full sm:w-auto px-8 md:px-10 py-4 md:py-5 bg-white text-slate-700 font-bold rounded-xl border border-slate-200 hover:bg-white hover:border-blue-600/30 hover:shadow-lg transition-all text-base md:text-lg flex items-center justify-center active:scale-95 group hover-lift overflow-hidden relative min-h-[44px]">
            <span class="relative z-10 flex items-center">
              Lihat Layanan <span data-lucide="chevron-down" class="ml-2 w-6 h-6 group-hover:translate-y-1 transition-transform"></span>
            </span>
          </a>
        </div>
        
        <div class="mt-20 md:mt-28 flex justify-center opacity-0 animate-reveal-delayed-3">
          <div class="hover-lift transition-all">
            <PerformanceBadge />
          </div>
        </div>
      </div>
    </div>
  </section>

  <SocialProof />

  <section id="layanan" class="section-spacing bg-white optimize-render">
    <div class="container-custom">
      <SectionHeader 
        preTitle="LAYANAN"
        title="Solusi Digital <span class='text-blue-600'>Menyeluruh</span>" 
        subtitle="Dari website hingga sistem cerdas, kami membantu akselerasi pertumbuhan bisnis Anda." 
      />

      <!-- Mobile View: Services Slider -->
      <div class="lg:hidden">
        <ServicesSlider client:load />
      </div>

      <!-- Desktop View: Static Grid -->
      <div class="hidden lg:grid lg:grid-cols-3 gap-8">
        {[
          {
            title: "Website Kustom",
            desc: "Arsitektur modern dengan performa Zero-JS yang super cepat.",
            icon: "code-2",
            features: ["Desain UI/UX Eksklusif", "SEO Local Optimization", "Kecepatan Akses Tinggi"]
          },
          {
            title: "IoT Solutions",
            desc: "Integrasi perangkat cerdas untuk otomatisasi operasional bisnis.",
            icon: "cpu",
            features: ["Real-time Monitoring", "Data Analytics Dashboard", "Hardware Integration"]
          },
          {
            title: "Sistem Informasi",
            desc: "Aplikasi internal untuk manajemen data dan efisiensi alur kerja.",
            icon: "database",
            features: ["Cloud Based Storage", "Multi-user Access Control", "Automated Reporting"]
          }
        ].map((item) => (
          <div class="card-padding-fluid card-standard hover:shadow-2xl hover:shadow-blue-600/10 shine-effect group flex flex-col h-full">
            <div class="w-12 h-12 md:w-16 md:h-16 bg-blue-600/10 rounded-xl flex items-center justify-center mb-6 md:mb-8 group-hover:bg-blue-600 transition-colors">
              <span data-lucide={item.icon} class="w-6 h-6 md:w-8 md:h-8 text-blue-600 group-hover:text-white transition-colors"></span>
            </div>
            <div class="flex-grow">
              <h4 class="mb-3 md:mb-4">{item.title}</h4>
              <p class="text-slate-600 mb-6 md:mb-8">{item.desc}</p>
              <ul class="space-y-2 md:space-y-3 mb-4">
                {item.features.map(feature => (
                  <li class="flex items-center text-caption text-slate-600 normal-case tracking-normal">
                    <span data-lucide="check" class="w-3.5 h-3.5 md:w-4 md:h-4 text-blue-600 mr-2"></span>
                    {feature}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 4. Portofolio / Studi Kasus Section -->
  <section id="portofolio" class="section-spacing bg-slate-50/50">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 md:gap-20 items-center">
        <div class="text-center lg:text-left">
          <SectionHeader 
            preTitle="PORTOFOLIO"
            title="Bukan Sekadar Kode, Tapi <span class='text-blue-600'>Hasil Nyata</span>" 
            subtitle="Lihat bagaimana kami membantu bisnis lokal bertransformasi dari offline ke ekosistem digital yang menghasilkan profit."
            align="left"
            class="mb-8"
          />
          <div class="grid grid-cols-2 gap-4 max-w-sm mx-auto lg:mx-0">
            <div class="bg-white p-5 md:p-6 card-standard border-blue-600/10">
              <p class="text-[clamp(1.5rem,5vw,2.5rem)] font-black text-blue-600 mb-1">50+</p>
              <p class="text-caption text-slate-500">Website Live</p>
            </div>
            <div class="bg-white p-5 md:p-6 card-standard border-blue-600/10">
              <p class="text-[clamp(1.5rem,5vw,2.5rem)] font-black text-blue-600 mb-1">99%</p>
              <p class="text-caption text-slate-500">Klien Puas</p>
            </div>
          </div>
        </div>
        <div class="p-3 md:p-4 card-standard shadow-xl group border-blue-600/5">
          <a href={latestProject ? `/portofolio/${latestProject.id}` : "/portofolio"}>
            <div class="bg-slate-100 aspect-video rounded-2xl overflow-hidden flex items-center justify-center border border-slate-200 relative">
              {latestProject?.data.images?.[0] ? (
                <Image 
                  src={latestProject.data.images[0]} 
                  alt={latestProject.data.title} 
                  width={800}
                  height={450}
                  format="webp"
                  quality={80}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" 
                  loading="lazy"
                />
              ) : (
                <span data-lucide="play-circle" class="w-16 h-16 text-slate-300"></span>
              )}
            </div>
            <div class="p-5 md:p-6 text-left">
              <p class="text-caption text-blue-600 mb-2">{latestProject?.data.category || 'Showcase Proyek'}</p>
              <h4 class="group-hover:text-blue-600 transition-colors">
                {latestProject?.data.title || 'Lihat Portofolio Kami'}
              </h4>
            </div>
          </a>
        </div>
      </div>
    </div>
  </section>

  <AreaGrid preTitle="WILAYAH" areas={areas} />

  <Workflow preTitle="PROSES" />

  <div class="section-spacing container-custom">
    <PricingTable />
  </div>

  <FAQ 
    preTitle="F.A.Q"
    items={[
      { q: "Apa perbedaan domain .my.id dan .com?", a: "Domain .my.id sangat ekonomis dan cocok untuk identitas personal/bisnis mikro. Domain .com atau .id memberikan kesan yang lebih profesional dan kredibilitas tinggi bagi bisnis skala menengah." },
      { q: "Apa yang dimaksud dengan Tanpa Biaya Hosting?", a: "Website kami dibangun dengan arsitektur statis yang di-host secara gratis di CDN global. Anda selamanya tidak perlu membayar tagihan bulanan atau tahunan untuk sewa hosting." },
      { q: "Berapa lama pengerjaan satu website?", a: "Untuk paket Starter, rata-rata selesai dalam 2-3 hari kerja setelah data lengkap kami terima." }
    ]} 
  />

  <!-- 7. Final CTA Section -->
  <section class="section-spacing bg-white optimize-render">
    <div class="container-custom">
      <div class="bg-gradient-to-br from-blue-600 to-blue-800 card-standard card-padding-fluid relative overflow-hidden text-center shadow-2xl shadow-blue-600/20 border-none">
        <h2 class="text-white mb-6 md:mb-8 relative z-10">Siap Membuat Bisnis Anda Online?</h2>
        <p class="text-white/90 mb-10 md:mb-12 max-w-xl mx-auto relative z-10 opacity-90">Konsultasi gratis, tanpa komitmen. Mari diskusikan bagaimana kami bisa membantu bisnis Anda tumbuh lebih besar di ekosistem digital.</p>
        <div class="relative z-10 flex justify-center">
          <WhatsAppCTA label="Chat WhatsApp Sekarang" variant="white" class="w-full sm:w-auto" />
        </div>

        <!-- Abstract Decorations -->
        <div class="absolute top-0 right-0 -translate-y-1/2 translate-x-1/4 w-[clamp(12rem,25vw,18rem)] aspect-square bg-white rounded-full blur-[60px] md:blur-[80px] opacity-10 animate-float"></div>
        <div class="absolute bottom-0 left-0 translate-y-1/2 -translate-x-1/4 w-[clamp(14rem,30vw,20rem)] aspect-square bg-blue-600 rounded-full blur-[70px] md:blur-[90px] opacity-10 animate-float-delayed"></div>
      </div>
    </div>
  </section>
</MainLayout>
