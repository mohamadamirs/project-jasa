---
import { getCollection, render } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';
import WhatsAppCTA from '../../components/WhatsAppCTA.astro';
import ImageSlider from '../../components/ImageSlider.astro';

export async function getStaticPaths() {
  const portfolioEntries = await getCollection('portfolios');
  return portfolioEntries.map(entry => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { title, category, description, tech, images = [] } = entry.data;
const { Content } = await render(entry);
---

<MainLayout {title} {description}>
  <article class="bg-white pb-24">
    <!-- Hero Detail -->
    <header class="pt-20 pb-16 bg-sky-50 border-b border-blue-100">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <span class="px-4 py-1.5 bg-blue-600 text-white text-xs font-bold uppercase tracking-widest rounded-full mb-6 inline-block">
          {category}
        </span>

        <h1 class="text-4xl md:text-6xl font-black text-slate-900 mb-8 tracking-tighter">
          {title}
        </h1>
        <div class="flex flex-wrap justify-center gap-3 mb-12">
          {tech.map(t => (
            <span class="px-4 py-1.5 bg-white border border-blue-200 text-blue-600 text-xs font-bold rounded-xl shadow-sm">
              {t}
            </span>
          ))}
        </div>

        <!-- IMAGE SLIDER -->
        {images.length > 0 && (
          <div class="mt-12">
            <ImageSlider {images} />
          </div>
        )}
      </div>
    </header>

    <!-- Content Detail -->
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 prose prose-slate prose-blue lg:prose-xl prose-p:leading-relaxed prose-headings:font-bold prose-headings:tracking-tight border-t border-slate-50">
      <Content />
    </div>

    <!-- CTA Footer -->
    <footer class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 mt-24">
      <div class="bg-blue-600 rounded-[2.5rem] md:rounded-[3rem] p-6 md:p-12 text-center text-white shadow-2xl shadow-blue-200 relative overflow-hidden">
        <h3 class="text-2xl md:text-3xl font-bold mb-6 relative z-10">Tertarik dengan sistem seperti ini?</h3>
        <p class="text-blue-100 mb-10 relative z-10 text-sm md:text-base">Mari bangun solusi digital yang tepat untuk bisnis Anda bersama tim Kutabaru.</p>
        <WhatsAppCTA 
          label="Pesan Proyek Serupa" 
          variant="white" 
          message={`Halo Kutabaru, saya tertarik dengan proyek ${title}. Bisa bantu buatkan sistem serupa?`}
          class="relative z-10" 
        />
        <span data-lucide="rocket" class="absolute -bottom-10 -right-10 w-48 md:w-64 h-48 md:h-64 text-blue-500 opacity-20"></span>
      </div>
    </footer>
  </article>
</MainLayout>
