---
import { getCollection, render } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';
import WhatsAppCTA from '../../components/WhatsAppCTA.astro';
import ImageSlider from '../../components/ImageSlider.astro';

export async function getStaticPaths() {
  const portfolioEntries = await getCollection('portfolios');
  return portfolioEntries.map(entry => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { title, category, description, tech, images = [] } = entry.data;
const { Content } = await render(entry);
---

<MainLayout {title} {description}>
  <article class="bg-white pb-24">
    <!-- Hero Detail -->
    <header class="pt-[clamp(5rem,15vh,10rem)] pb-[clamp(3rem,8vh,6rem)] bg-slate-50/50 border-b border-blue-600/10 px-[clamp(1rem,5vw,2.5rem)]">
      <div class="max-w-4xl mx-auto text-center">
        <span class="px-4 py-1.5 bg-blue-600 text-white text-caption rounded-full mb-6 inline-block">
          {category}
        </span>

        <h1 class="mb-8">
          {title}
        </h1>
        <div class="flex flex-wrap justify-center gap-3 mb-12">
          {tech.map(t => (
            <span class="px-4 py-1.5 bg-white border border-blue-600/10 text-blue-600 text-caption rounded-xl shadow-sm">
              {t}
            </span>
          ))}
        </div>

        <!-- IMAGE SLIDER -->
        {images.length > 0 && (
          <div class="mt-12">
            <ImageSlider {images} />
          </div>
        )}
      </div>
    </header>

    <!-- Content Detail -->
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 prose prose-slate prose-blue lg:prose-xl prose-p:leading-relaxed prose-headings:font-bold prose-headings:tracking-tight border-t border-slate-50">
      <Content />
    </div>

    <!-- CTA Footer -->
    <footer class="max-w-4xl mx-auto px-[clamp(1rem,5vw,2.5rem)] mt-24">
      <div class="bg-blue-600 rounded-[clamp(1.25rem,5vw,2rem)] p-8 md:p-16 text-center text-white shadow-2xl shadow-blue-600/20 relative overflow-hidden group">
        <h3 class="mb-6 relative z-10 text-white">Tertarik dengan sistem seperti ini?</h3>
        <p class="text-white/90 mb-10 relative z-10 opacity-90">Mari bangun solusi digital yang tepat untuk bisnis Anda bersama tim Kutabaru.</p>
        <div class="relative z-10">
          <WhatsAppCTA 
            label="Pesan Proyek Serupa" 
            message={`Halo Kutabaru, saya melihat portofolio ${title} dan tertarik untuk proyek serupa.`} 
            variant="white"
            class="w-full sm:w-auto"
          />
        </div>
        <span data-lucide="rocket" class="absolute -bottom-10 -right-10 w-48 md:w-64 h-48 md:h-64 text-white/10 group-hover:rotate-12 transition-transform duration-500"></span>
      </div>
    </footer>
  </article>
</MainLayout>
